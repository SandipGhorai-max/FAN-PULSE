{
  "name": "fanpulse-ai-backend",
  "version": "1.0.0",
  "description": "FanPulse AI — GenAI Multi-Agent Backend for FIFA World Cup 2026",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon --ignore '*.db' --ignore '*.db-journal' server.js",
    "seed": "node db/seed.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext .js",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@google/genai": "^2.11.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "express-validator": "^7.3.2",
    "helmet": "^8.0.0",
    "socket.io": "^4.8.1",
    "uuid": "^11.1.0",
    "xss-clean": "^0.1.4",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "eslint": "^9.17.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.4.2",
    "supertest": "^7.0.0",
    "vitest": "^3.0.4"
  }
}
